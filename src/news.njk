---
layout: base.njk
title: News
permalink: /news/
---

<div class="archive-container">
  <div class="archive-intro">
    <span class="archive-tag">External Feed</span>
    <h1 class="archive-title">{{ title }}</h1>
    <div class="archive-line"></div>
  </div>

  <div class="project-list" id="news-grid">
    {% for item in news %}
      <a href="{{ item.url }}" class="project-card news-card" target="_blank" rel="noopener">
        <div class="card-image-wrapper">
          {% if item.preview and item.preview.image and (item.preview.image.localUrl or item.preview.image.url) %}
            <img src="{{ item.preview.image.localUrl if item.preview.image.localUrl else item.preview.image.url }}" alt="{{ item.preview.title }}" class="preview-img">
          {% else %}
            <div class="image-placeholder loading-shimmer"></div>
          {% endif %}
          <div class="date-badge">{{ item.date }}</div>
        </div>
        
        <div class="card-content">
          <h2 class="card-title">
            {% if item.preview and item.preview.title %}
              {{ item.preview.title }}
            {% else %}
              Untitled Article
            {% endif %}
          </h2>
          <div class="card-description-container">
            <p class="card-description">
              {% if item.preview and item.preview.description %}
                {{ item.preview.description }}
              {% else %}
                No description available.
              {% endif %}
            </p>
          </div>
          <span class="card-link">Visit Website →</span>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

<style>
  /* GRID SETUP - Ensures all cards in a row match height */
  .project-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    grid-auto-rows: 1fr; /* This is the secret for equal height rows */
    gap: 2rem;
  }

  .project-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column; /* Stack image and content */
    height: 100%; /* Fill the grid cell */
    background: #fff;
    border: 1px solid var(--border-color, #eee);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.06);
  }

  .card-image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #f4f4f4;
    position: relative;
    flex-shrink: 0; /* Prevents image from squishing */
  }

  .preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .date-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    padding: 4px 8px;
    font-size: 0.7rem;
    font-weight: 700;
    border-radius: 4px;
    backdrop-filter: blur(4px);
  }

  .card-content {
    padding: 1.5rem;
    flex-grow: 1; /* Pushes the 'View Project' link to the bottom */
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 0.75rem 0;
    line-height: 1.3;
    /* Limit title to 2 lines to keep things tidy */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-description {
    font-size: 0.95rem;
    line-height: 1.5;
    color: #666;
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3; /* Allows slightly more description */
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-link {
    margin-top: auto; /* Aligns link to the bottom of the card */
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--accent, #000);
    opacity: 0.6;
  }

  /* LOADING ANIMATION */
  .loading-shimmer {
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>